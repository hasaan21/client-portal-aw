# Copy to .env and fill in local values. Never commit real secrets.

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
FLASK_APP=run.py

# Database (SQLite).
# NOTE: a relative sqlite path (three slashes) is resolved by Flask-SQLAlchemy
# against Flask's instance folder (i.e. <project>/instance), NOT the CWD.
# So `sqlite:///portal.db` -> <project>/instance/portal.db.
# For an absolute path use four slashes, e.g. sqlite:////data/portal.db (Railway).
DATABASE_URL=sqlite:///portal.db

# PDF output directory. Resolved relative to CWD (project root during dev).
# On Railway this is /data/pdfs.
PDF_OUTPUT_DIR=instance/pdfs

# Session / cookies. Set to true in prod (HTTPS only).
SESSION_COOKIE_SECURE=false
REMEMBER_COOKIE_DURATION_DAYS=14

# Seed users (used only by scripts/seed.py; can be omitted)
SEED_ADMIN_PASSWORD=change-me-locally
