# Copy to .env and fill in local values. Never commit real secrets.

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
FLASK_APP=run.py

# Database (SQLite path). On Railway this is set to /data/portal.db.
DATABASE_URL=sqlite:///instance/portal.db

# PDF output directory. On Railway this is /data/pdfs.
PDF_OUTPUT_DIR=instance/pdfs

# Session / cookies
SESSION_COOKIE_SECURE=false        # true in prod (HTTPS only)
REMEMBER_COOKIE_DURATION_DAYS=14

# Seed users (used only by scripts/seed.py; can be omitted)
SEED_ADMIN_PASSWORD=change-me-locally
